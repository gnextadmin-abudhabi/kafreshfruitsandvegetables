---
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../../data/business';
import { serviceTypes, getServiceBySlug } from '../../data/serviceTypes';
import { serviceAreas, getAreaBySlug } from '../../data/serviceAreas';
import { serviceUrl, areaUrl, comboUrl, contactUrl } from '../../lib/urls';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SeoFaq from '../../components/SeoFaq.astro';

import type { ServiceType } from '../../data/serviceTypes';

export function getStaticPaths() {
  return serviceTypes.map((service) => ({
    params: { service: service.slug },
    props: { service },
  }));
}

interface Props {
  service: ServiceType;
}

const { service } = Astro.props;

const mbz = getAreaBySlug('mohammed-bin-zayed-city')!;

const pageTitle = `${service.name} in MBZ City & Abu Dhabi`;
const metaDescription = service.description.length > 155
  ? service.description.slice(0, 152) + '...'
  : service.description;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: service.name,
  description: service.description,
  brand: {
    '@type': 'Brand',
    name: business.name,
  },
  offers: {
    '@type': 'AggregateOffer',
    lowPrice: service.priceRanges[0]?.min ?? 0,
    highPrice: service.priceRanges[0]?.max ?? 0,
    priceCurrency: 'AED',
    availableAtOrFrom: {
      '@type': 'Place',
      name: business.name,
      address: {
        '@type': 'PostalAddress',
        streetAddress: business.address.street,
        addressLocality: business.address.city,
        addressRegion: business.address.state,
        addressCountry: business.address.country,
      },
    },
  },
};
---

<BaseLayout title={pageTitle} description={metaDescription} schema={schema}>
  <Breadcrumbs
    crumbs={[
      { label: 'Our Products', href: '/services/' },
      { label: service.name },
    ]}
  />

  <section class="gradient-cream py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="lg:flex lg:items-start lg:gap-12">
        <div class="lg:flex-1">
          <div class="flex items-center gap-3 text-brand-600">
            <div class="flex size-10 items-center justify-center rounded-lg bg-gradient-to-br from-brand-50 to-brand-100">
              <Icon name={service.icon} class="size-6" />
            </div>
            <span class="text-sm font-semibold uppercase tracking-wide">
              <span class="en-text">{service.name}</span>
              <span class="ar-text hidden">{service.arName}</span>
            </span>
          </div>

          <h1 class="mt-4 font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
            <span class="en-text">{service.name} in MBZ City & Abu Dhabi</span>
            <span class="ar-text hidden">{service.arName} في مدينة محمد بن زايد وأبوظبي</span>
          </h1>

          <p class="mt-6 max-w-3xl text-lg leading-relaxed text-stone-600">
            <span class="en-text">{service.description}</span>
            <span class="ar-text hidden">{service.arDescription}</span>
          </p>

          <div class="mt-6 inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-brand-50 to-brand-100 px-5 py-3 text-sm font-medium text-brand-800 ring-1 ring-brand-200/60">
            <Icon name="lucide:tag" class="size-4 text-brand-500" />
            <span class="en-text">Starting from AED {service.priceRanges[0]?.min ?? 0}</span>
            <span class="ar-text hidden">يبدأ من {service.priceRanges[0]?.min ?? 0} درهم إماراتي</span>
          </div>
        </div>

        <div class="mt-8 lg:mt-0 lg:w-96 lg:shrink-0">
          <img
            src={service.image}
            alt={`${service.name} at ${business.name}`}
            class="rounded-xl shadow-lg"
            width="1024"
            height="1024"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-stone-200/60 gradient-subtle py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
        <span class="en-text">Our {service.name} Process</span>
        <span class="ar-text hidden">عملية {service.arName} لدينا</span>
      </h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        <span class="en-text">Every product follows a clear process so you know exactly what to expect.</span>
        <span class="ar-text hidden">يتبع كل منتج عملية واضحة لتعرف بالضبط ما يمكن توقعه.</span>
      </p>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {service.process.map((step, index) => (
          <div class="relative rounded-xl border border-stone-200/60 bg-white p-6">
            <div class="flex size-10 items-center justify-center rounded-full bg-gradient-to-br from-brand-700 to-brand-800 text-sm font-bold text-white">
              {index + 1}
            </div>
            <h3 class="mt-4 text-base font-semibold text-stone-900">
              <span class="en-text">{step.title}</span>
              <span class="ar-text hidden">{step.arTitle}</span>
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">
              <span class="en-text">{step.description}</span>
              <span class="ar-text hidden">{step.arDescription}</span>
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
      <span class="en-text">Areas We Serve for {service.name}</span>
      <span class="ar-text hidden">المناطق التي نخدمها لـ {service.arName}</span>
    </h2>
    <p class="mt-3 max-w-2xl text-stone-600">
      <span class="en-text">We provide {service.name.toLowerCase()} across MBZ City, Musaffah, Shabiya, and greater Abu Dhabi. Select your area for local availability and delivery options.</span>
      <span class="ar-text hidden">نقدم {service.arName} عبر مدينة محمد بن زايد والمصفح والشابية وأبوظبي الكبرى. اختر منطقتك للتحقق من التوفر المحلي وخيارات التوصيل.</span>
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {serviceAreas.map((area) => (
        <a
          href={comboUrl(area.slug, service.slug)}
          class="group rounded-xl border border-stone-200/60 bg-white p-5 transition-all hover:border-brand-200 hover:shadow-md"
        >
          <div class="flex items-center gap-3">
            <div class="flex size-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-50 to-brand-100">
              <Icon name="lucide:map-pin" class="size-4 text-brand-500" />
            </div>
            <span class="font-semibold text-stone-800 group-hover:text-brand-800">
              <span class="en-text">{area.name}</span>
              <span class="ar-text hidden">{area.name}</span>
            </span>
          </div>
          <p class="mt-2 text-sm text-stone-500">{area.county}</p>
          <p class="mt-1 text-xs text-stone-400">
            <span class="en-text">Delivery: {area.responseTime}</span>
            <span class="ar-text hidden">التوصيل: {area.responseTime}</span>
          </p>
        </a>
      ))}
    </div>
  </section>

  <div class="border-t border-stone-200/60 gradient-subtle">
    <SeoFaq area={mbz} service={service} />
  </div>

  <section class="gradient-cta relative overflow-hidden py-16">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(98,180,16,0.15),_transparent_60%)]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(244,124,0,0.08),_transparent_50%)]" />
    <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
      <h2 class="font-display text-2xl text-white sm:text-3xl">
        <span class="en-text">Interested in {service.name}?</span>
        <span class="ar-text hidden">مهتم بـ {service.arName}؟</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-brand-200">
        <span class="en-text">{business.name} serves MBZ City, Musaffah, and Shabiya with daily fresh produce. Call us today or visit our shop on Al Ithmid St.</span>
        <span class="ar-text hidden">يخدم {business.name} مدينة محمد بن زايد والمصفح والشابية بمنتجات طازجة يوميًا. اتصل بنا اليوم أو قم بزيارة متجرنا في شارع الإثمد.</span>
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 rounded-lg gradient-warm px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:opacity-90"
        >
          <Icon name="lucide:phone" class="size-4" />
          {business.phone}
        </a>
        <a
          href={contactUrl()}
          class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
        >
          <Icon name="lucide:mail" class="size-4" />
          <span class="en-text">Send a Message</span>
          <span class="ar-text hidden">إرسال رسالة</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
