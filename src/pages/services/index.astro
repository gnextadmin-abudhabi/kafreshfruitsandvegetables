---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../../data/business';
import { serviceTypes } from '../../data/serviceTypes';
import { serviceUrl, contactUrl } from '../../lib/urls';
---

<BaseLayout
  title={`Our Products | ${business.name}`}
  description={`${business.name} offers a full range of fresh fruits, vegetables, leafy greens, herbs, seasonal produce, delivery, and bulk orders across ${business.serviceRadius}.`}
>
  <Breadcrumbs crumbs={[{ label: 'Our Products' }]} />

  <section class="gradient-cream py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="max-w-3xl animate-fade-up">
        <span class="inline-flex items-center gap-2 rounded-full bg-brand-100 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700" data-i18n data-i18n-en="Fresh Daily" data-i18n-ar="طازج يوميًا">
          <Icon name="lucide:apple" class="size-3.5" />
          Fresh Daily
        </span>
        <h1 class="mt-4 font-display text-4xl text-brand-900 sm:text-5xl" data-i18n data-i18n-en="Our Products" data-i18n-ar="منتجاتنا">
          Our Products
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-stone-600" data-i18n data-i18n-en="From daily essentials to specialty items, we provide a wide selection of fresh produce for homes, restaurants, cafeterias, and kitchens throughout our service area." data-i18n-ar="من الضروريات اليومية إلى المنتجات المتخصصة، نوفر تشكيلة واسعة من المنتجات الطازجة للمنازل والمطاعم والمقاصف والمطابخ في جميع أنحاء منطقة خدمتنا.">
          From daily essentials to specialty items, we provide a wide
          selection of fresh produce for homes, restaurants, cafeterias, and kitchens
          throughout our service area.
        </p>
      </div>
    </div>
  </section>

  <section class="pb-16 lg:pb-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {serviceTypes.map((service, i) => (
          <a
            href={serviceUrl(service.slug)}
            class={`card-hover group relative rounded-xl border border-stone-200/80 bg-white p-6 animate-fade-up stagger-${Math.min(i + 1, 6)}`}
          >
            <div class="flex size-12 items-center justify-center rounded-xl bg-gradient-to-br from-brand-50 to-brand-100 text-brand-700 transition-all group-hover:from-brand-100 group-hover:to-brand-200">
              <Icon name={service.icon} class="size-6" />
            </div>
            <h2 class="mt-4 font-display text-lg text-brand-900">
              <span class="en-text">{service.name}</span>
              <span class="ar-text hidden">{service.arName}</span>
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">
              <span class="en-text">{service.description.slice(0, 100)}...</span>
              <span class="ar-text hidden">{service.arDescription.slice(0, 100)}...</span>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="gradient-cta relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(98,180,16,0.15),_transparent_60%)]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(244,124,0,0.08),_transparent_50%)]" />
    <div class="relative mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl text-white" data-i18n data-i18n-en="Not Sure What You Need?" data-i18n-ar="غير متأكد مما تحتاجه؟">Not Sure What You Need?</h2>
          <p class="mt-2 text-brand-200" data-i18n data-i18n-en="Call us and tell us what you are looking for. We will help you find the right fresh produce." data-i18n-ar="اتصل بنا وأخبرنا بما تبحث عنه. سنساعدك في العثور على المنتجات الطازجة المناسبة.">
            Call us and tell us what you are looking for. We will help you find the right fresh produce.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg gradient-warm px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:opacity-90"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone}
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
            data-i18n
            data-i18n-en="Send a Message"
            data-i18n-ar="إرسال رسالة"
          >
            Send a Message
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
