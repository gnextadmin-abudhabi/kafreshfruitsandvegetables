---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
import { products, productCategories } from '../data/products';
import { contactUrl } from '../lib/urls';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'KA Fresh Product Catalog',
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.name,
      description: `${p.name} - Fresh produce from KA Fresh`,
      offers: {
        '@type': 'Offer',
        price: p.price,
        priceCurrency: 'AED',
        availability: p.inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
      },
    },
  })),
};
---

<BaseLayout
  title={`Our Product Catalog | Fresh Produce | ${business.name}`}
  description={`Browse our complete catalog of fresh fruits, vegetables, leafy greens, and herbs. Daily fresh stock with delivery across MBZ City, Musaffah, and Shabiya.`}
  schema={schema}
>
  <Breadcrumbs crumbs={[{ label: 'Products' }]} />

  <!-- Hero -->
  <section class="relative overflow-hidden gradient-hero">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(98,180,16,0.25),_transparent_60%)]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(244,124,0,0.08),_transparent_50%)]" />
    <div class="relative mx-auto max-w-7xl px-5 py-16 text-center lg:px-8 lg:py-24">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-300 ring-1 ring-white/10 backdrop-blur-sm">
        <Icon name="lucide:sparkles" class="size-3.5" />
        <span class="en-text">Daily Fresh Stock</span>
        <span class="ar-text hidden">مخزون طازج يوميًا</span>
      </span>
      <h1 class="mt-4 font-display text-4xl text-white sm:text-5xl lg:text-6xl">
        <span class="en-text">Our Product Catalog</span>
        <span class="ar-text hidden">كتالوج منتجاتنا</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-brand-200">
        <span class="en-text">Handpicked fresh fruits, vegetables, greens, and herbs. Sourced daily for the best quality and flavor.</span>
        <span class="ar-text hidden">فواكه وخضروات وأوراق خضراء وأعشاب منتقاة بعناية. يتم sourcing يوميًا لأفضل جودة ونكهة.</span>
      </p>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="border-b border-stone-200/60 bg-white sticky top-0 z-30">
    <div class="mx-auto max-w-7xl px-5 py-4 lg:px-8">
      <div class="flex items-center gap-2 overflow-x-auto pb-1 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" id="category-filters">
        {productCategories.map((cat) => (
          <button
            type="button"
            data-category={cat.slug}
            class={`filter-btn shrink-0 rounded-full px-5 py-2 text-sm font-semibold transition-all ${cat.slug === 'all' ? 'bg-brand-700 text-white shadow-md' : 'bg-stone-100 text-stone-600 hover:bg-brand-50 hover:text-brand-700'}`}
          >
            <span class="en-text">{cat.name}</span>
            <span class="ar-text hidden">{cat.arName}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Product Grid -->
  <section class="gradient-cream py-12 lg:py-20">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div id="product-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {products.map((product, i) => (
          <div
            class={`product-card group relative overflow-hidden rounded-2xl border border-stone-200/60 bg-white shadow-sm transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:border-brand-200 scroll-reveal scroll-reveal-delay-${Math.min((i % 8) + 1, 6)}`}
            data-category={product.category}
          >
            {/* Gradient overlay on hover */}
            <div class="absolute inset-0 bg-gradient-to-t from-brand-900/80 via-brand-900/20 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100 z-10 pointer-events-none" />

            {/* Image */}
            <div class="relative aspect-square overflow-hidden bg-stone-100">
              <img
                src={product.image}
                alt={`${product.name} - ${product.arName}`}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                width="600"
                height="600"
                loading="lazy"
              />

              {/* Badge */}
              {product.badge && (
                <div class={`absolute left-3 top-3 z-20 rounded-full ${product.badgeColor} px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white shadow-lg`}>
                  <span class="en-text">{product.badge}</span>
                  <span class="ar-text hidden">{product.arBadge}</span>
                </div>
              )}

              {/* Quick action overlay */}
              <div class="absolute inset-x-0 bottom-0 z-20 flex items-end justify-center gap-3 pb-5 opacity-0 transition-all duration-500 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0">
                <a
                  href={business.phoneHref}
                  class="inline-flex items-center gap-1.5 rounded-full bg-white px-4 py-2 text-xs font-bold text-brand-800 shadow-lg transition-transform hover:scale-105"
                >
                  <Icon name="lucide:phone" class="size-3.5" />
                  <span class="en-text">Order</span>
                  <span class="ar-text hidden">اطلب</span>
                </a>
                <a
                  href={contactUrl()}
                  class="inline-flex items-center gap-1.5 rounded-full bg-white/90 backdrop-blur px-4 py-2 text-xs font-bold text-brand-800 shadow-lg transition-transform hover:scale-105"
                >
                  <Icon name="lucide:message-square" class="size-3.5" />
                  <span class="en-text">Inquire</span>
                  <span class="ar-text hidden">استفسر</span>
                </a>
              </div>
            </div>

            {/* Info */}
            <div class="relative p-5">
              {/* Category tag */}
              <span class="inline-block rounded-md bg-brand-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-brand-600">
                <span class="en-text">{productCategories.find(c => c.slug === product.category)?.name}</span>
                <span class="ar-text hidden">{productCategories.find(c => c.slug === product.category)?.arName}</span>
              </span>

              {/* Name */}
              <h3 class="mt-2 font-display text-lg text-brand-900 leading-tight">
                <span class="en-text">{product.name}</span>
                <span class="ar-text hidden">{product.arName}</span>
              </h3>

              {/* Price */}
              <div class="mt-3 flex items-baseline gap-2">
                <span class="text-2xl font-bold text-brand-700">
                  <span class="en-text">AED {product.price.toFixed(2)}</span>
                  <span class="ar-text hidden">{product.arPrice} درهم</span>
                </span>
                <span class="text-sm text-stone-400">
                  <span class="en-text">/ {product.unit}</span>
                  <span class="ar-text hidden">/ {product.arUnit}</span>
                </span>
              </div>

              {/* Stock status */}
              <div class="mt-3 flex items-center gap-1.5">
                <span class={`inline-block size-2 rounded-full ${product.inStock ? 'bg-green-500' : 'bg-red-400'}`} />
                <span class="text-xs font-medium text-stone-500">
                  <span class="en-text">{product.inStock ? 'In Stock' : 'Out of Stock'}</span>
                  <span class="ar-text hidden">{product.inStock ? 'متوفر' : 'غير متوفر'}</span>
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="gradient-cta relative overflow-hidden py-16">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(98,180,16,0.15),_transparent_60%)]" />
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(244,124,0,0.08),_transparent_50%)]" />
    <div class="relative mx-auto max-w-4xl px-5 text-center lg:px-8">
      <h2 class="font-display text-2xl text-white sm:text-3xl">
        <span class="en-text">Need Something Specific?</span>
        <span class="ar-text hidden">هل تحتاج إلى شيء محدد؟</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-brand-200">
        <span class="en-text">Prices shown are indicative and may vary based on seasonality and market rates. Call us for today's exact prices.</span>
        <span class="ar-text hidden">الأسعار المعروضة تقريبية وقد تختلف بناءً على الموسمية وأسعار السوق. اتصل بنا للحصول على الأسعار الدقيقة اليوم.</span>
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 rounded-lg gradient-warm px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all hover:opacity-90"
        >
          <Icon name="lucide:phone" class="size-4" />
          {business.phone}
        </a>
        <a
          href={contactUrl()}
          class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
        >
          <Icon name="lucide:message-square" class="size-4" />
          <span class="en-text">Send a Message</span>
          <span class="ar-text hidden">أرسل رسالة</span>
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var buttons = document.querySelectorAll('.filter-btn');
      var cards = document.querySelectorAll('.product-card');

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var category = btn.getAttribute('data-category');

          // Update active button
          buttons.forEach(function(b) {
            b.classList.remove('bg-brand-700', 'text-white', 'shadow-md');
            b.classList.add('bg-stone-100', 'text-stone-600');
          });
          btn.classList.remove('bg-stone-100', 'text-stone-600');
          btn.classList.add('bg-brand-700', 'text-white', 'shadow-md');

          // Filter cards
          cards.forEach(function(card) {
            var cardCat = card.getAttribute('data-category');
            if (category === 'all' || cardCat === category) {
              card.style.display = '';
              setTimeout(function() {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
              }, 50);
            } else {
              card.style.opacity = '0';
              card.style.transform = 'translateY(20px)';
              setTimeout(function() {
                card.style.display = 'none';
              }, 300);
            }
          });
        });
      });
    })();
  </script>
</BaseLayout>
