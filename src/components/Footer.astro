---
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
import { serviceTypes } from '../data/serviceTypes';
import { serviceAreas } from '../data/serviceAreas';
import { serviceUrl, areaUrl } from '../lib/urls';
---

<footer class="bg-brand-950 text-white">
  <div class="h-px w-full bg-gradient-to-r from-transparent via-brand-500/40 to-transparent" />

  <div class="mx-auto max-w-7xl px-5 pb-10 pt-16 lg:px-8">
    <!-- Top section: brand + tagline -->
    <div class="border-b border-white/10 pb-10">
      <a href="/" class="group inline-flex items-center gap-4">
        <img
          src="/images/logo-white.png"
          alt={`${business.name} logo`}
          class="size-20 rounded-2xl object-contain"
          width="512"
          height="512"
          loading="lazy"
        />
        <div class="flex flex-col">
          <span class="font-display text-3xl text-white">KA Fresh</span>
          <span class="text-xs font-medium uppercase tracking-[0.18em] text-brand-300">
            Fruits & Vegetables
          </span>
        </div>
      </a>
      <p class="mt-5 max-w-md text-sm leading-relaxed text-stone-300" data-i18n data-i18n-en={`${business.tagline} Fresh produce shop in MBZ City, Abu Dhabi. Daily fresh fruits, vegetables, leafy greens, herbs, and seasonal produce for homes, restaurants, and kitchens.`} data-i18n-ar={`${business.tagline} محل خضروات وفواكه طازجة في مدينة محمد بن زايد، أبوظبي. فواكه وخضروات وأعشاب طازجة يومياً للمنازل والمطاعم والمطابخ.`}>
        {business.tagline} Fresh produce shop in MBZ City, Abu Dhabi. Daily fresh fruits, vegetables, leafy greens, herbs, and seasonal produce for homes, restaurants, and kitchens.
      </p>
    </div>

    <!-- Link columns -->
    <div class="grid gap-8 pt-10 sm:grid-cols-2 lg:grid-cols-3">
      <!-- Column 1: Our Products -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-brand-300" data-i18n data-i18n-en="Our Products" data-i18n-ar="منتجاتنا">
          Our Products
        </h3>
        <ul class="space-y-2.5">
          {serviceTypes.map((service) => (
            <li>
              <a
                href={serviceUrl(service.slug)}
                class="text-sm text-stone-300 transition-colors hover:text-white"
              >
                <span class="en-text">{service.name}</span>
                <span class="ar-text hidden">{service.arName}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 2: Areas We Serve -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-brand-300" data-i18n data-i18n-en="Areas We Serve" data-i18n-ar="مناطق التوصيل">
          Areas We Serve
        </h3>
        <ul class="space-y-2.5">
          {serviceAreas.map((area) => (
            <li>
              <a
                href={areaUrl(area.slug)}
                class="text-sm text-stone-300 transition-colors hover:text-white"
              >
                {area.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact Info + Map -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-brand-300" data-i18n data-i18n-en="Contact Info" data-i18n-ar="معلومات التواصل">
          Contact Info
        </h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2.5">
            <Icon name="lucide:map-pin" class="mt-0.5 size-4 shrink-0 text-brand-400" />
            <span class="text-sm text-stone-300">
              {business.address.street && `${business.address.street}, `}{business.address.city}, {business.address.country}
            </span>
          </li>
          <li class="flex items-start gap-2.5">
            <Icon name="lucide:phone" class="mt-0.5 size-4 shrink-0 text-brand-400" />
            <a
              href={business.phoneHref}
              class="text-sm text-stone-300 transition-colors hover:text-white"
            >
              {business.phone}
            </a>
          </li>
          <li class="flex items-start gap-2.5">
            <Icon name="lucide:mail" class="mt-0.5 size-4 shrink-0 text-brand-400" />
            <a
              href={`mailto:${business.email}`}
              class="text-sm text-stone-300 transition-colors hover:text-white"
            >
              {business.email}
            </a>
          </li>
          <li class="flex items-start gap-2.5">
            <Icon name="lucide:clock" class="mt-0.5 size-4 shrink-0 text-brand-400" />
            <div class="text-sm text-stone-300">
              {business.hours.map((schedule) => (
                <p>{schedule.days}: {schedule.hours}</p>
              ))}
            </div>
          </li>
        </ul>

        <div class="mt-5 overflow-hidden rounded-xl border border-white/10">
          <iframe
            src="https://maps.google.com/maps?q=Al+Ithmid+Street,+MBZ+City,+ME10,+Abu+Dhabi&z=16&output=embed"
            width="100%"
            height="180"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`${business.name} location on Google Maps`}
          ></iframe>
        </div>

        <div class="mt-4 flex items-center gap-2">
          <span class="text-xs font-medium text-stone-400" data-i18n data-i18n-en="Follow us:" data-i18n-ar="تابعنا:">Follow us:</span>
          <a
            href="https://www.instagram.com/kavegetables"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-lg p-2 text-stone-400 transition-all hover:bg-pink-500/20 hover:text-pink-400"
            aria-label="Instagram"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=61591289946296"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-lg p-2 text-stone-400 transition-all hover:bg-blue-500/20 hover:text-blue-400"
            aria-label="Facebook"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a
            href="https://wa.me/971545801898"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-lg p-2 text-stone-400 transition-all hover:bg-green-500/20 hover:text-green-400"
            aria-label="WhatsApp"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-white/15 pt-6 sm:flex-row">
      <p class="text-xs text-stone-200">
        &copy; {new Date().getFullYear()} {business.legalName}. All rights reserved.
      </p>
      <div class="flex gap-4 text-xs text-stone-200">
        <a
          href="https://gxlocate.com"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-brand-300"
        >
          Powered by gxlocate.com
        </a>
      </div>
    </div>
  </div>
</footer>
