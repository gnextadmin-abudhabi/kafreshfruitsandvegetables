---
import { Icon } from 'astro-icon/components';
import { business } from '../data/business';
---

<header
  class="sticky top-0 z-50 w-full border-b border-stone-200/60 bg-white/80 backdrop-blur-xl backdrop-saturate-150 transition-shadow duration-300"
  id="site-header"
>
  <div class="mx-auto flex h-[72px] max-w-7xl items-center justify-between px-5 lg:px-8">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-3">
      <img
        src={business.logo}
        alt={`${business.name} logo`}
        class="size-14 rounded-lg object-contain"
        width="128"
        height="128"
        loading="eager"
      />
      <div class="flex flex-col">
        <span class="font-display text-xl leading-none tracking-tight text-brand-900">
          KA Fresh
        </span>
        <span class="text-[11px] font-medium uppercase tracking-[0.18em] text-stone-400">
          Fruits & Vegetables
        </span>
      </div>
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden items-center gap-1 lg:flex">
      <a
        href="/services/"
        class="rounded-lg px-3.5 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="Our Products"
        data-i18n-ar="منتجاتنا"
      >
        Our Products
      </a>
      <a
        href="/areas/"
        class="rounded-lg px-3.5 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="Areas We Serve"
        data-i18n-ar="مناطق التوصيل"
      >
        Areas We Serve
      </a>
      <a
        href="/about/"
        class="rounded-lg px-3.5 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="About"
        data-i18n-ar="من نحن"
      >
        About
      </a>
      <a
        href="/contact/"
        class="rounded-lg px-3.5 py-2 text-sm font-medium text-stone-600 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="Contact"
        data-i18n-ar="اتصل بنا"
      >
        Contact
      </a>
    </nav>

    <!-- Right side actions -->
    <div class="flex items-center gap-2">
      <!-- Social icons -->
      <div class="hidden items-center gap-1 sm:flex">
        <a
          href="https://www.instagram.com/kavegetables"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-lg p-2.5 text-stone-400 transition-all hover:bg-pink-50 hover:text-pink-600"
          aria-label="Follow us on Instagram"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/profile.php?id=61591289946296"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-lg p-2.5 text-stone-400 transition-all hover:bg-blue-50 hover:text-blue-600"
          aria-label="Follow us on Facebook"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
        <a
          href="https://wa.me/971545801898"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-lg p-2.5 text-stone-400 transition-all hover:bg-green-50 hover:text-green-600"
          aria-label="Chat on WhatsApp"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      </div>

      <!-- Language toggle -->
      <button
        type="button"
        id="lang-toggle"
        class="hidden items-center gap-1 rounded-lg border border-stone-200 bg-white px-2.5 py-2 text-xs font-semibold transition-colors hover:bg-stone-50 sm:inline-flex"
        aria-label="Switch language"
      >
        <span id="lang-en" class="rounded bg-brand-700 px-1.5 py-0.5 text-white">EN</span>
        <span class="text-stone-300">/</span>
        <span id="lang-ar" class="rounded px-1.5 py-0.5 text-stone-500">AR</span>
      </button>

      <a
        href={business.phoneHref}
        class="inline-flex items-center gap-2 rounded-lg bg-brand-800 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-all hover:bg-brand-700 hover:shadow-md"
      >
        <Icon name="lucide:phone" class="size-4" />
        <span class="hidden sm:inline">{business.phone}</span>
        <span class="sm:hidden">Call</span>
      </a>

      <button
        type="button"
        class="inline-flex size-10 items-center justify-center rounded-lg text-stone-500 transition-colors hover:bg-stone-100 hover:text-stone-700 lg:hidden"
        aria-label="Toggle menu"
        id="mobile-menu-btn"
      >
        <Icon name="lucide:menu" class="size-5" id="menu-icon-open" />
        <Icon name="lucide:x" class="hidden size-5" id="menu-icon-close" />
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="hidden border-t border-stone-100 bg-white lg:hidden" id="mobile-menu">
    <nav class="mx-auto max-w-7xl space-y-1 px-5 py-4">
      <a
        href="/services/"
        class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="Our Products"
        data-i18n-ar="منتجاتنا"
      >
        <Icon name="lucide:apple" class="size-4 text-stone-400" />
        <span data-i18n data-i18n-en="Our Products" data-i18n-ar="منتجاتنا">Our Products</span>
      </a>
      <a
        href="/areas/"
        class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="Areas We Serve"
        data-i18n-ar="مناطق التوصيل"
      >
        <Icon name="lucide:map-pin" class="size-4 text-stone-400" />
        <span data-i18n data-i18n-en="Areas We Serve" data-i18n-ar="مناطق التوصيل">Areas We Serve</span>
      </a>
      <a
        href="/about/"
        class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="About"
        data-i18n-ar="من نحن"
      >
        <Icon name="lucide:info" class="size-4 text-stone-400" />
        <span data-i18n data-i18n-en="About" data-i18n-ar="من نحن">About</span>
      </a>
      <a
        href="/contact/"
        class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-stone-700 transition-colors hover:bg-brand-50 hover:text-brand-800"
        data-i18n
        data-i18n-en="Contact"
        data-i18n-ar="اتصل بنا"
      >
        <Icon name="lucide:mail" class="size-4 text-stone-400" />
        <span data-i18n data-i18n-en="Contact" data-i18n-ar="اتصل بنا">Contact</span>
      </a>
      <div class="pt-2">
        <a
          href={business.phoneHref}
          class="flex w-full items-center justify-center gap-2 rounded-lg bg-brand-800 px-4 py-2.5 text-sm font-medium text-white"
        >
          <Icon name="lucide:phone" class="size-4" />
          Call {business.phone}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });

  const header = document.getElementById('site-header');
  window.addEventListener(
    'scroll',
    () => {
      if (window.scrollY > 8) {
        header?.classList.add('shadow-sm');
      } else {
        header?.classList.remove('shadow-sm');
      }
    },
    { passive: true },
  );

  // Language toggle
  const langToggle = document.getElementById('lang-toggle');
  const langEn = document.getElementById('lang-en');
  const langAr = document.getElementById('lang-ar');

  function updateLangButton() {
    var current = localStorage.getItem('ka-lang') || 'en';
    if (current === 'ar') {
      langEn?.classList.remove('bg-brand-700', 'text-white');
      langEn?.classList.add('text-stone-500');
      langAr?.classList.add('bg-brand-700', 'text-white');
      langAr?.classList.remove('text-stone-500');
    } else {
      langEn?.classList.add('bg-brand-700', 'text-white');
      langEn?.classList.remove('text-stone-500');
      langAr?.classList.remove('bg-brand-700', 'text-white');
      langAr?.classList.add('text-stone-500');
    }
  }

  updateLangButton();

  langToggle?.addEventListener('click', function() {
    var current = localStorage.getItem('ka-lang') || 'en';
    var next = current === 'en' ? 'ar' : 'en';
    localStorage.setItem('ka-lang', next);
    document.documentElement.lang = next;
    document.documentElement.dir = next === 'ar' ? 'rtl' : 'ltr';
    document.body.classList.toggle('rtl-active', next === 'ar');
    updateLangButton();

    // Apply translations
    var isAr = next === 'ar';
    document.querySelectorAll('[data-i18n]').forEach(function(el) {
      var text = isAr ? el.getAttribute('data-i18n-ar') : el.getAttribute('data-i18n-en');
      if (text !== null) {
        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
          el.placeholder = text;
        } else {
          el.textContent = text;
        }
      }
    });
    document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
      var html = isAr ? el.getAttribute('data-i18n-ar') : el.getAttribute('data-i18n-en');
      if (html !== null) el.innerHTML = html;
    });
    // Toggle bilingual spans for dynamic content
    document.querySelectorAll('.en-text').forEach(function(el) {
      el.classList.toggle('hidden', isAr);
    });
    document.querySelectorAll('.ar-text').forEach(function(el) {
      el.classList.toggle('hidden', !isAr);
    });
  });
</script>
