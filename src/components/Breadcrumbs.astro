---
interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const allCrumbs: Crumb[] = [{ label: 'Home', href: '/' }, ...crumbs];

const schemaItems = allCrumbs.map((crumb, index) => {
  const entry: Record<string, unknown> = {
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.label,
  };
  if (crumb.href) {
    entry.item = new URL(crumb.href, Astro.site).href;
  }
  return entry;
});

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: schemaItems,
};

function crumbAr(label: string): string {
  const map: Record<string, string> = {
    Home: 'الرئيسية',
    Blog: 'المدونة',
  };
  return map[label] || label;
}
---

<nav
  aria-label="Breadcrumb"
  class="mx-auto max-w-7xl px-5 py-3 lg:px-8"
  data-i18n
  data-i18n-en="Breadcrumb"
  data-i18n-ar="مسار التنقل"
>
  <ol class="flex flex-wrap items-center gap-1.5 text-sm">
    {allCrumbs.map((crumb, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && (
          <span class="text-stone-300" aria-hidden="true">/</span>
        )}
        {crumb.href ? (
          <a
            href={crumb.href}
            class="text-stone-500 transition-colors hover:text-stone-700"
            data-i18n
            data-i18n-en={crumb.label}
            data-i18n-ar={crumbAr(crumb.label)}
          >
            {crumb.label}
          </a>
        ) : (
          <span
            class="text-stone-700"
            data-i18n
            data-i18n-en={crumb.label}
            data-i18n-ar={crumbAr(crumb.label)}
          >
            {crumb.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
